          "settings": {
            "code": "<style>\n#m2-landing{\n    --green:#0B6E4F; --green-deep:#074535; --green-mid:#C2E5D8; --green-light:#E8F5F0;\n    --ink:#0F1117; --ink-60:#6B6B6B; --ink-30:#ADADAD; --bg:#F5F5F3; --surface:#FFFFFF;\n    --border:#E2E2DE; --rojo:#C0392B; --ambar:#B8860B;\n  }#m2-landing *{box-sizing:border-box;margin:0;padding:0}#m2-landing{scroll-behavior:smooth}#m2-landing{font-family:'Inter',sans-serif;color:var(--ink);background:var(--surface);line-height:1.6;-webkit-font-smoothing:antialiased}#m2-landing a{color:inherit;text-decoration:none}#m2-landing .wrap{max-width:1080px;margin:0 auto;padding:0 32px}#m2-landing h1, #m2-landing h2, #m2-landing h3{font-weight:800;letter-spacing:-.035em;line-height:1.08}#m2-landing .eyebrow{font-size:13px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--green)}#m2-landing section{padding:96px 0}#m2-landing .center{text-align:center}#m2-landing .muted{color:var(--ink-60)}#m2-landing .tnum{font-variant-numeric:tabular-nums}#m2-landing nav{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.85);backdrop-filter:blur(10px);border-bottom:1px solid var(--border)}#m2-landing nav .wrap{display:flex;align-items:center;justify-content:space-between;height:64px}#m2-landing .wordmark{font-weight:700;font-size:19px;letter-spacing:-.03em}#m2-landing .wordmark .pe{color:var(--green)}#m2-landing .nav-links{display:flex;align-items:center;gap:26px}#m2-landing .nav-links a{font-size:14px;color:var(--ink-60);font-weight:500;transition:color .15s}#m2-landing .nav-links a:hover{color:var(--ink)}#m2-landing .btn{display:inline-flex;align-items:center;gap:8px;font-weight:600;font-size:15px;border-radius:11px;padding:12px 22px;cursor:pointer;transition:transform .15s ease,background .15s ease,box-shadow .15s ease;border:none;font-family:inherit}#m2-landing .btn-green{background:var(--green);color:#fff}#m2-landing .btn-green:hover{background:var(--green-deep);transform:translateY(-2px);box-shadow:0 10px 24px rgba(11,110,79,.28)}#m2-landing .btn-ghost{background:transparent;color:var(--ink);border:1px solid var(--border)}#m2-landing .btn-ghost:hover{border-color:var(--ink-30)}#m2-landing .btn-lg{padding:15px 28px;font-size:16px;border-radius:13px}@media(max-width:680px){.nav-links a.hide-sm{display:none}}#m2-landing .hero{position:relative;overflow:hidden;padding:90px 0 80px}#m2-landing .hero::before{content:\"\";position:absolute;inset:0;z-index:0;pointer-events:none;opacity:.6;\n    background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);\n    background-size:46px 46px;-webkit-mask:radial-gradient(120% 80% at 78% 8%,#000,transparent 72%);mask:radial-gradient(120% 80% at 78% 8%,#000,transparent 72%)}#m2-landing .hero .wrap{position:relative;z-index:1;display:grid;grid-template-columns:1.05fr .95fr;gap:54px;align-items:center}#m2-landing .hero h1{font-size:clamp(38px,5.4vw,62px)}#m2-landing .hero .sub{font-size:20px;color:var(--ink-60);margin-top:22px;max-width:520px}#m2-landing .hero .cta-row{display:flex;gap:14px;margin-top:34px;flex-wrap:wrap}#m2-landing .hero .trust{margin-top:22px;font-size:13px;color:var(--ink-60);display:flex;gap:18px;flex-wrap:wrap}#m2-landing .hero .trust span{display:flex;align-items:center;gap:6px}#m2-landing .hero .trust svg{width:15px;height:15px;stroke:var(--green);fill:none;stroke-width:2}#m2-landing .badge-pill{display:inline-flex;align-items:center;gap:8px;background:var(--green-light);color:var(--green-deep);font-size:13px;font-weight:600;padding:7px 14px;border-radius:99px;margin-bottom:22px}#m2-landing .badge-pill .d{width:7px;height:7px;border-radius:50%;background:var(--green)}#m2-landing .mock{background:var(--surface);border:1px solid var(--border);border-radius:20px;box-shadow:0 1px 3px rgba(0,0,0,.06),0 18px 50px rgba(15,17,23,.10);padding:24px;position:relative}#m2-landing .mock .top{display:flex;align-items:center;justify-content:space-between;padding-bottom:16px;border-bottom:1px solid var(--border)}#m2-landing .mock .top .wm{font-weight:700;font-size:15px;letter-spacing:-.03em}#m2-landing .mock .top .wm .pe{color:var(--green)}#m2-landing .mock .top .step{font-size:12px;color:var(--ink-60)}#m2-landing .score-row{display:flex;gap:14px;align-items:center;margin-top:18px}#m2-landing .scorebadge{width:60px;height:60px;border-radius:15px;color:#fff;display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:700;flex:none}#m2-landing .score-row b{font-size:17px}#m2-landing .score-row p{font-size:13px;color:var(--ink-60);margin-top:2px}#m2-landing .pbar{height:11px;border-radius:6px;background:linear-gradient(90deg,var(--green-light),var(--green-mid),var(--green));position:relative;margin:30px 0 8px}#m2-landing .pbar .mk{position:absolute;top:-24px;transform:translateX(-50%);font-size:11px;font-weight:700;white-space:nowrap}#m2-landing .pbar .mk::after{content:\"\";position:absolute;left:50%;top:18px;width:2px;height:13px;background:var(--ink);transform:translateX(-50%)}#m2-landing .pbar-x{display:flex;justify-content:space-between;font-size:11px;color:var(--ink-60);font-weight:600}#m2-landing .mini-alert{margin-top:18px;background:#FBEAE8;border-left:3px solid var(--rojo);border-radius:9px;padding:12px 14px}#m2-landing .mini-alert .t{font-size:12px;font-weight:600;color:#8E2A20;margin-bottom:6px}#m2-landing .mini-alert .l{font-size:12.5px;color:#8E2A20;display:flex;gap:7px;margin-top:3px}#m2-landing .band{background:var(--green-deep);color:#fff}#m2-landing .band .eyebrow{color:var(--green-mid)}#m2-landing .band h2{font-size:clamp(28px,4vw,40px);color:#fff}#m2-landing .band p{color:#A9CFC2}#m2-landing .pain{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:40px}#m2-landing .pain .p{background:#0a3a2c;border-radius:16px;padding:26px}#m2-landing .pain .p .q{font-size:30px}#m2-landing .pain .p h3{font-size:17px;color:#fff;margin:12px 0 6px}#m2-landing .pain .p p{font-size:14px}#m2-landing .vp{display:grid;grid-template-columns:1fr 1fr;gap:26px;margin-top:48px}#m2-landing .vcard{border:1px solid var(--border);border-radius:20px;padding:34px;background:var(--surface);transition:transform .2s ease,box-shadow .2s ease}#m2-landing .vcard:hover{transform:translateY(-4px);box-shadow:0 18px 40px rgba(15,17,23,.08)}#m2-landing .vicon{width:52px;height:52px;border-radius:14px;background:var(--green-light);display:flex;align-items:center;justify-content:center;margin-bottom:20px}#m2-landing .vicon svg{width:26px;height:26px;stroke:var(--green);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}#m2-landing .vcard h3{font-size:23px}#m2-landing .vcard p{font-size:15px;color:var(--ink-60);margin-top:10px}#m2-landing .vcard ul{margin:18px 0 0;padding:0;list-style:none}#m2-landing .vcard li{font-size:14px;display:flex;gap:10px;margin-bottom:9px}#m2-landing .vcard li svg{width:18px;height:18px;stroke:var(--green);fill:none;stroke-width:2.2;flex:none;margin-top:2px}#m2-landing .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:48px}#m2-landing .step{position:relative;padding-top:8px}#m2-landing .step .n{width:38px;height:38px;border-radius:11px;background:var(--ink);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px}#m2-landing .step h3{font-size:18px;margin:16px 0 6px}#m2-landing .step p{font-size:14px;color:var(--ink-60)}#m2-landing .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:44px}#m2-landing .stat{background:var(--bg);border-radius:16px;padding:28px 20px;text-align:center}#m2-landing .stat .n{font-weight:800;font-size:34px;letter-spacing:-.03em;color:var(--green-deep)}#m2-landing .stat .l{font-size:13px;color:var(--ink-60);margin-top:6px}#m2-landing .quote{font-size:clamp(24px,3.4vw,34px);font-weight:700;letter-spacing:-.02em;line-height:1.25;max-width:820px}#m2-landing .quote .hl{color:var(--green-mid)}#m2-landing .faq{max-width:760px;margin:44px auto 0}#m2-landing .faq details{border-bottom:1px solid var(--border);padding:20px 0}#m2-landing .faq summary{font-weight:600;font-size:17px;cursor:pointer;list-style:none;display:flex;justify-content:space-between;gap:16px}#m2-landing .faq summary::-webkit-details-marker{display:none}#m2-landing .faq summary::after{content:\"+\";color:var(--green);font-weight:700;font-size:22px;line-height:1}#m2-landing .faq details[open] summary::after{content:\"–\"}#m2-landing .faq p{font-size:15px;color:var(--ink-60);margin-top:12px}#m2-landing .cta-final{background:var(--green);color:#fff;border-radius:28px;padding:64px 40px;text-align:center;position:relative;overflow:hidden}#m2-landing .cta-final::before{content:\"\";position:absolute;inset:0;opacity:.5;background-image:linear-gradient(rgba(255,255,255,.12) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.12) 1px,transparent 1px);background-size:34px 34px;-webkit-mask:radial-gradient(100% 100% at 50% 0%,#000,transparent 75%);mask:radial-gradient(100% 100% at 50% 0%,#000,transparent 75%)}#m2-landing .cta-final .inner{position:relative;z-index:1}#m2-landing .cta-final h2{font-size:clamp(28px,4vw,42px);color:#fff}#m2-landing .cta-final p{color:#D6EFE7;font-size:18px;margin:16px auto 0;max-width:520px}#m2-landing .cta-final .btn-white{background:#fff;color:var(--green-deep);margin-top:30px}#m2-landing .cta-final .btn-white:hover{transform:translateY(-2px);box-shadow:0 12px 30px rgba(0,0,0,.2)}#m2-landing footer{border-top:1px solid var(--border);padding:50px 0;margin-top:96px}#m2-landing footer .row{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:20px}#m2-landing footer .links{display:flex;gap:24px;font-size:14px;color:var(--ink-60)}#m2-landing footer .copy{font-size:13px;color:var(--ink-30);margin-top:20px}#m2-landing .section-head{max-width:680px}#m2-landing .section-head h2{font-size:clamp(28px,4vw,42px);margin-top:14px}#m2-landing .section-head p{font-size:18px;color:var(--ink-60);margin-top:16px}@media(max-width:860px){\n    .hero .wrap{grid-template-columns:1fr;gap:40px}\n    .vp,.pain,.steps,.stats{grid-template-columns:1fr}\n    .stats{grid-template-columns:repeat(2,1fr)}\n    .pain{grid-template-columns:1fr}\n  }@media (prefers-reduced-motion: reduce){#m2-landing *{animation:none!important;transition:none!important}}\n</style>\n<div id=\"m2-landing\">\n<!-- NAV -->\n<nav>\n  <div class=\"wrap\">\n    <span class=\"wordmark\">m2<span class=\"pe\">peru</span>.com</span>\n    <div class=\"nav-links\">\n      <a href=\"#como\" class=\"hide-sm\">Cómo funciona</a>\n      <a href=\"#herramientas\" class=\"hide-sm\">Herramientas</a>\n      <a href=\"#confianza\" class=\"hide-sm\">Por qué confiar</a>\n      <a href=\"/\" class=\"btn btn-green\">Evaluar gratis</a>\n    </div>\n  </div>\n</nav>\n\n<!-- HERO -->\n<header class=\"hero\">\n  <div class=\"wrap\">\n    <div>\n      <span class=\"badge-pill\"><span class=\"d\"></span>Gratis · sin tarjeta · resultado al instante</span>\n      <h1>¿Estás pagando lo justo<br>por esa propiedad?</h1>\n      <p class=\"sub\">m2peru te dice en segundos si el precio está bajo, dentro o sobre el mercado de su distrito. Y si la evalúas como inversión, te dice si de verdad va a tener retorno, una vez descontadas hipoteca, alquiler e inflación.</p>\n      <div class=\"cta-row\">\n        <a href=\"/\" class=\"btn btn-green btn-lg\">Evaluar mi propiedad</a>\n        <a href=\"#como\" class=\"btn btn-ghost btn-lg\">Ver cómo funciona</a>\n      </div>\n      <div class=\"trust\">\n        <span><svg viewBox=\"0 0 24 24\"><path d=\"M20 6L9 17l-5-5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>Comparables reales del distrito</span>\n        <span><svg viewBox=\"0 0 24 24\"><path d=\"M20 6L9 17l-5-5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>Inflación oficial BCRP</span>\n        <span><svg viewBox=\"0 0 24 24\"><path d=\"M20 6L9 17l-5-5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>Sin jerga</span>\n      </div>\n    </div>\n\n    <!-- Mock de resultado -->\n    <div class=\"mock\">\n      <div class=\"top\">\n        <span class=\"wm\">m2<span class=\"pe\">peru</span>.com</span>\n        <span class=\"step\">Resultado</span>\n      </div>\n      <div class=\"score-row\">\n        <div class=\"scorebadge\" style=\"background:var(--green)\">A</div>\n        <div>\n          <b>Bajo el mercado</b>\n          <p>El precio está por debajo de comparables del distrito.</p>\n        </div>\n      </div>\n      <div class=\"pbar\"><div class=\"mk tnum\" style=\"left:30%\">Tu precio</div></div>\n      <div class=\"pbar-x tnum\"><span>$2,400</span><span>Mediana $2,640</span><span>$2,900</span></div>\n      <div class=\"mini-alert\">\n        <div class=\"t\">En resumen · como inversión</div>\n        <div class=\"l\"><b>✓</b><span>¿Le gana a la inflación? 6.1% vs 4.1%</span></div>\n        <div class=\"l\"><b>✓</b><span>¿Rinde más que el banco? 7.4% vs 4.5%</span></div>\n      </div>\n    </div>\n  </div>\n</header>\n\n<!-- PROBLEMA -->\n<section class=\"band\">\n  <div class=\"wrap\">\n    <div class=\"eyebrow\">El problema</div>\n    <h2 style=\"margin-top:14px\">El mercado inmobiliario<br>está lleno de humo</h2>\n    <p style=\"margin-top:16px;max-width:640px;font-size:18px\">«Esta zona se está revalorizando», «es una gran inversión», «el precio es de oportunidad». Frases que venden, pero que nadie respalda con números. Así se compra caro y se invierte en lo que no rinde.</p>\n    <div class=\"pain\">\n      <div class=\"p\">\n        <div class=\"q\">🤷</div>\n        <h3>No sabes si el precio es justo</h3>\n        <p>Te dan un número y no tienes con qué compararlo. El que vende decide la conversación.</p>\n      </div>\n      <div class=\"p\">\n        <div class=\"q\">📈</div>\n        <h3>«Plusvalía» que engaña</h3>\n        <p>El precio sube, pero si no le gana a la inflación, en realidad estás perdiendo poder adquisitivo.</p>\n      </div>\n      <div class=\"p\">\n        <div class=\"q\">🏦</div>\n        <h3>Retorno que no existe</h3>\n        <p>Con hipoteca, comisiones e impuestos, muchas «inversiones» rinden menos que el banco.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- VALUE PROPS -->\n<section id=\"herramientas\">\n  <div class=\"wrap\">\n    <div class=\"section-head\">\n      <div class=\"eyebrow\">Lo que resuelve</div>\n      <h2>Dos preguntas, respondidas con datos</h2>\n      <p>No es un portal de avisos. Es un evaluador que te pone del lado del que decide, no del que vende.</p>\n    </div>\n\n    <div class=\"vp\">\n      <div class=\"vcard\">\n        <div class=\"vicon\"><svg viewBox=\"0 0 24 24\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"M21 21l-4.3-4.3\"/></svg></div>\n        <h3>¿Compras a buen precio?</h3>\n        <p>Comparamos el precio contra los percentiles de propiedades reales del mismo distrito, área y dormitorios. Te decimos en una palabra: bajo, dentro o sobre el mercado.</p>\n        <ul>\n          <li><svg viewBox=\"0 0 24 24\"><path d=\"M20 6L9 17l-5-5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>Rango de precio por m² de la zona</li>\n          <li><svg viewBox=\"0 0 24 24\"><path d=\"M20 6L9 17l-5-5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>Cuánto estás por encima o debajo de la mediana</li>\n          <li><svg viewBox=\"0 0 24 24\"><path d=\"M20 6L9 17l-5-5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>Munición real para negociar</li>\n        </ul>\n      </div>\n      <div class=\"vcard\">\n        <div class=\"vicon\"><svg viewBox=\"0 0 24 24\"><rect x=\"4\" y=\"3\" width=\"16\" height=\"18\" rx=\"2\"/><path d=\"M8 7h8M8 11h8M8 15h5\"/></svg></div>\n        <h3>¿Va a tener retorno?</h3>\n        <p>La calculadora toma el caso completo —hipoteca, alquiler, plusvalía e inflación— y te dice sin maquillaje si la inversión vale la pena frente a alternativas seguras.</p>\n        <ul>\n          <li><svg viewBox=\"0 0 24 24\"><path d=\"M20 6L9 17l-5-5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>¿La ganancia le gana a la inflación?</li>\n          <li><svg viewBox=\"0 0 24 24\"><path d=\"M20 6L9 17l-5-5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>¿Rinde más que un depósito a plazo?</li>\n          <li><svg viewBox=\"0 0 24 24\"><path d=\"M20 6L9 17l-5-5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>Cuánto te cuesta el alquiler que no cubre la cuota</li>\n        </ul>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- COMO FUNCIONA -->\n<section id=\"como\" style=\"background:var(--bg)\">\n  <div class=\"wrap\">\n    <div class=\"section-head\">\n      <div class=\"eyebrow\">Cómo funciona</div>\n      <h2>Tres pasos, treinta segundos</h2>\n      <p>Sin registro para empezar. Llenas lo básico y al instante tienes el veredicto.</p>\n    </div>\n    <div class=\"steps\">\n      <div class=\"step\">\n        <div class=\"n\">1</div>\n        <h3>Ubicación</h3>\n        <p>Eliges el distrito y el tipo de propiedad. Solo lo esencial.</p>\n      </div>\n      <div class=\"step\">\n        <div class=\"n\">2</div>\n        <h3>Características</h3>\n        <p>Área, dormitorios y poco más. Mientras más datos, más preciso el resultado.</p>\n      </div>\n      <div class=\"step\">\n        <div class=\"n\">3</div>\n        <h3>Precio y veredicto</h3>\n        <p>Pones el precio y al instante ves si es justo, y si conviene como inversión.</p>\n      </div>\n    </div>\n    <div style=\"text-align:center;margin-top:44px\">\n      <a href=\"/\" class=\"btn btn-green btn-lg\">Probar ahora, gratis</a>\n    </div>\n  </div>\n</section>\n\n<!-- HONESTIDAD -->\n<section class=\"band\" id=\"honestidad\">\n  <div class=\"wrap\">\n    <div class=\"eyebrow\">Por qué somos distintos</div>\n    <p class=\"quote\" style=\"margin-top:18px\">Te decimos la verdad,<br><span class=\"hl\">aunque no sea la que querías oír.</span></p>\n    <p style=\"margin-top:24px;max-width:640px;font-size:18px\">Una propiedad puede subir de precio y aun así hacerte perder plata. Si la apreciación no le gana a la inflación, y el alquiler no cubre la cuota, esa «gran inversión» rinde menos que dejar el dinero en el banco. La mayoría de herramientas te muestran solo lo bonito. Nosotros te mostramos el número real.</p>\n    <div class=\"stats\">\n      <div class=\"stat\" style=\"background:#0a3a2c\"><div class=\"n\" style=\"color:#fff\">21.2%</div><div class=\"l\" style=\"color:#A9CFC2\">Inflación acumulada que erosiona tu capital</div></div>\n      <div class=\"stat\" style=\"background:#0a3a2c\"><div class=\"n\" style=\"color:#fff\">4.5%</div><div class=\"l\" style=\"color:#A9CFC2\">Lo que rinde el banco, sin riesgo</div></div>\n      <div class=\"stat\" style=\"background:#0a3a2c\"><div class=\"n\" style=\"color:#fff\">S/&amp;$</div><div class=\"l\" style=\"color:#A9CFC2\">Cálculos en soles y dólares</div></div>\n      <div class=\"stat\" style=\"background:#0a3a2c\"><div class=\"n\" style=\"color:#fff\">BCRP</div><div class=\"l\" style=\"color:#A9CFC2\">Inflación oficial 2010–2026</div></div>\n    </div>\n  </div>\n</section>\n\n<!-- CONFIANZA -->\n<section id=\"confianza\">\n  <div class=\"wrap\">\n    <div class=\"section-head\">\n      <div class=\"eyebrow\">Por qué confiar</div>\n      <h2>Datos reales, lenguaje claro</h2>\n      <p>Nada de cifras infladas ni promesas. Todo lo que decimos se apoya en datos que puedes verificar.</p>\n    </div>\n    <div class=\"vp\" style=\"grid-template-columns:repeat(3,1fr)\">\n      <div class=\"vcard\">\n        <div class=\"vicon\"><svg viewBox=\"0 0 24 24\"><path d=\"M4 20V10M10 20V4M16 20v-7M22 20H2\"/></svg></div>\n        <h3 style=\"font-size:19px\">Comparables reales</h3>\n        <p>Percentiles de propiedades publicadas en el mismo distrito, no un promedio inventado.</p>\n      </div>\n      <div class=\"vcard\">\n        <div class=\"vicon\"><svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M12 7v5l3 2\"/></svg></div>\n        <h3 style=\"font-size:19px\">Inflación oficial</h3>\n        <p>Usamos la inflación del BCRP año por año para mostrar tu ganancia real, no la nominal.</p>\n      </div>\n      <div class=\"vcard\">\n        <div class=\"vicon\"><svg viewBox=\"0 0 24 24\"><path d=\"M8 10h8M8 14h5\"/><rect x=\"3\" y=\"4\" width=\"18\" height=\"16\" rx=\"2\"/></svg></div>\n        <h3 style=\"font-size:19px\">Sin jerga</h3>\n        <p>Nada de «cap rate» ni «plusvalía anualizada». Preguntas que cualquiera entiende.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- FAQ -->\n<section style=\"background:var(--bg)\">\n  <div class=\"wrap\">\n    <div class=\"section-head center\" style=\"margin:0 auto\">\n      <div class=\"eyebrow\">Preguntas frecuentes</div>\n      <h2>Lo que todos preguntan</h2>\n    </div>\n    <div class=\"faq\">\n      <details open>\n        <summary>¿De dónde sacan los precios de mercado?</summary>\n        <p>De propiedades reales publicadas en los portales inmobiliarios del Perú. Calculamos los percentiles (P25, mediana, P75) por distrito, tipo y tamaño, para comparar tu caso con propiedades parecidas.</p>\n      </details>\n      <details>\n        <summary>¿Es gratis?</summary>\n        <p>Sí. Evaluar una propiedad y calcular su retorno como inversión es gratis y no necesitas tarjeta.</p>\n      </details>\n      <details>\n        <summary>¿Qué necesito para la calculadora de inversión?</summary>\n        <p>Lo básico de tu caso: precio de compra, área, alquiler estimado y, si es financiado, la cuota y el saldo de tu crédito. El resto lo asumimos con supuestos de mercado que puedes ajustar.</p>\n      </details>\n      <details>\n        <summary>¿Por qué una propiedad que sube de precio puede ser mala inversión?</summary>\n        <p>Porque «subir de precio» no es lo mismo que «ganar». Si la subida no le gana a la inflación, pierdes poder adquisitivo. Y si el alquiler no cubre la cuota de la hipoteca, pones plata de tu bolsillo cada mes. Nosotros mostramos ese número real.</p>\n      </details>\n    </div>\n  </div>\n</section>\n\n<!-- CTA FINAL -->\n<section>\n  <div class=\"wrap\">\n    <div class=\"cta-final\">\n      <div class=\"inner\">\n        <h2>Antes de firmar, evalúalo.</h2>\n        <p>Treinta segundos pueden ahorrarte una mala compra o una inversión que no rinde.</p>\n        <a href=\"/\" class=\"btn btn-white btn-lg\">Evaluar mi propiedad gratis</a>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- FOOTER -->\n<footer>\n  <div class=\"wrap\">\n    <div class=\"row\">\n      <span class=\"wordmark\">m2<span class=\"pe\">peru</span>.com</span>\n      <div class=\"links\">\n        <a href=\"#como\">Cómo funciona</a>\n        <a href=\"#herramientas\">Herramientas</a>\n        <a href=\"#confianza\">Por qué confiar</a>\n        <a href=\"/\">Evaluar gratis</a>\n      </div>\n    </div>\n    <p class=\"copy\">m2peru · El valor real de tu metro cuadrado. · Los resultados son estimaciones basadas en data de mercado público.</p>\n  </div>\n</footer>\n</div>",
