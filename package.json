{
  "name": "valuador-pe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Valuador PE — valuador de propiedades + calculadora de inversión (modelo Caso Surquillo) leyendo MongoDB Atlas",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "install:frontend": "npm install --prefix frontend",
    "install:all": "npm install && npm install --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run install:all && npm run build:frontend",
    "dev:backend": "node --watch backend/server.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "test": "node --test backend/*.test.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "mongodb": "^6.10.0"
  },
  "engines": {
    "node": ">=20"
  }
}
